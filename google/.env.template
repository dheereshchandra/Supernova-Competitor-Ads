# Copy this file to .env (no extension) and fill in the values.
# .env is gitignored. NEVER commit it.

# ---- Cloudflare R2 credentials ----
# Get these from Cloudflare → R2 → Manage R2 API Tokens → Create API Token,
# scoped to JUST the bucket you'll use here. Permissions: Object Read & Write.

R2_ACCOUNT_ID=
R2_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket and public URL for this pipeline.
# Recommended: a dedicated bucket so Google and FB artefacts don't mix.
# Acceptable alternative: reuse the FB bucket with a 'g_' key prefix (see HANDOVER §8).
R2_BUCKET=google-video-ads
R2_PUBLIC_URL_BASE=https://pub-<hash>.r2.dev

# ---- Gemini (Step 4 only) ----
# Get from Google AI Studio: https://aistudio.google.com/apikey
# The cost-approval gate in Step 4 will block any API call until the operator
# explicitly approves the estimated batch cost.
GEMINI_API_KEY=
